@{
    ViewData["Title"] = "Chyba serveru";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="display-1 fw-bold text-danger">500</div>

            <h2 class="mb-3">Chyba serveru</h2>

            <p class="text-muted mb-4">
                Něco se pokazilo na naší straně.
                Omlouváme se za komplikace — zkuste to prosím později.
            </p>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-danger mt-4">
                    @ViewBag.Message
                </div>
            }

            <a href="/" class="btn btn-danger btn-lg px-4">
                Zpět na úvodní stránku
            </a>

        </div>
    </div>
</div>
