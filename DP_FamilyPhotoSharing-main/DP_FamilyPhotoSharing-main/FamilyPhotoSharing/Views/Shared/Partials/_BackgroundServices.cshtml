async function startReencryptForm(data) {

    // Modal dialog
    const modal = new bootstrap.Modal(document.getElementById("progressModal"), {
        backdrop: 'static',
        keyboard: false
    });

    modal.show();

    await new Promise(r => setTimeout(r, 50));
    
    // Pooling
    pollStatus(data.jobId);
}

async function pollStatus(jobId) {
    const input = document.getElementById("backgroundRefreshBlocker");
    const block = input !== null;

    const interval = setInterval(async () => {
        const res = await fetch(`/Background/Status/${jobId}`);
        if (res.status === 404) {
            return; // jen přeskočíme tento tick
        }

        if (!res.ok) {
            clearInterval(interval);

            const modalEl = document.getElementById("progressModal");
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();
            showToast("Došlo k chybě při komunikaci se serverem.", TOAST_DANGER);
            return;
        }

        const data = await res.json();
        console.log("Polling...", jobId);

        updateProgress(data.percent);

        if (data.status === "Completed") {
            clearInterval(interval);
            updateProgress(100);

            setTimeout(() => {
                bootstrap.Modal.getInstance(document.getElementById("progressModal")).hide();
                if(!Boolean(block))
                    location.reload();
            }, 500);
        }

        if (data.status === "Failed") {
            clearInterval(interval);
            const modalEl = document.getElementById("progressModal");
            const modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) modal.hide();
            showToast("Došlo k chybě: " + data.error, TOAST_DANGER);
        }

    }, 500);
}

function updateProgress(percent) {
    const bar = document.getElementById("progressBar");
    bar.style.width = percent + "%";
    bar.innerText = percent + "%";
}

</script>