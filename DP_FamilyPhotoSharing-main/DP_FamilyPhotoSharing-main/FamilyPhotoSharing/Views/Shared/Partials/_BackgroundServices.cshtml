    async function BS_ChangeUsersSharedAlbum(userIds, albumId) {
    const request = {
        UserIds: userIds,
        AlbumId: albumId
    };

    const res = await fetch("/Background/Start_ChangeUsersSharedAlbum", {
        method: "POST",
