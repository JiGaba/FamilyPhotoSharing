@using ModelLayer.PhotoEnums;

<style>
    #progressBar {
        transition: width 0.4s ease;
    }
</style>

<div id="uploadPanel" class="collapse mt-3">
    <h4 class="mb-3">Hromadné nahrávání souborů</h4>

    <p class="text-muted">Maximální velikost jednoho souboru je 50 MB.</p>

    <div class="mb-3">
        <label for="files" class="form-label">Vyberte soubory</label>
        <input type="file" id="files" class="form-control" multiple accept="@TextEnumHelper.AcceptImages" />
    </div>

    <button id="uploadBtn" class="btn btn-primary">Nahrát</button>

    <div class="mt-4">
        <div id="status" class="mb-2 text-secondary">Čekám na zahájení uploadu…</div>
        <div class="progress" style="height: 25px;">
            <div id="progressBarUpload"
                 class="progress-bar progress-bar-striped progress-bar-animated"
                 role="progressbar"
                 style="width: 0%">
                0%
            </div>
        </div>

    </div>

    <ul id="uploadedList"
        class="list-group mt-3"
        style="display:none; max-height: 200px; overflow-y: auto;">
    </ul>
    <hr class="my-3" style="border-top: 2px solid #e0e0e0; opacity: 1;">
    <br />
</div>

<script>
    document.getElementById("uploadBtn").addEventListener("click", async () => {
        document.getElementById("uploadBtn").disabled = true;

        const type = document.getElementById("uploadTypeId").value;
        if(type != "1" && type != "2"){
            showToast("Není určen typ uloadu! Kontaktujte prosím administrátora webu.", TOAST_DANGER);
            document.getElementById("uploadBtn").disabled = false;
            return;
        }
        const url = type == "1" ? "/Upload/UploadSingle" : "/Upload/UploadMultiple"
        // Smazání listu souborů při opětovném vkládání dat
        const ul = document.getElementById("uploadedList");
        if(ul) ul.innerText = "";

        const files = document.getElementById("files").files;
        if (files.length === 0) {
            showToast("Není vybrán žádný soubor!", TOAST_DANGER);
            document.getElementById("uploadBtn").disabled = false;
            return;
        }

        const total = files.length;
        let uploaded = 0;
        let responseOk = true;

        for (let i = 0; i < total; i++) {
            let formData = new FormData();
            let errorText;
            formData.append("file", files[i]);

            try {
                const response = await fetch(url, {
                    method: "POST",
                    body: formData
                });
                
                if (!response.ok) {
                    // server vrátil chybu (např. 400 Bad Request)
                    errorText = await response.text();
                    responseOk = false;
                }

            } catch (err) {
                // chyba na síti nebo fetch
                errorText = err;
                responseOk = false;
            }

            uploaded++;
            ReloadProgressBar(i+1, uploaded, total, files[i].name, responseOk, errorText);
        }

        if(responseOk)
            location.reload();

        document.getElementById("status").innerText = "Hotovo!";
        document.getElementById("uploadBtn").disabled = false;

    });

    function ReloadProgressBar(index, uploaded, total, fileName, responseOk, errorText = ""){
         let percent = Math.round((uploaded / total) * 100);

         let trimmedErrorText = errorText.length > 100
            ? errorText.substring(0, 100)
            : errorText;

        document.getElementById("status").innerText =
            `Nahráno ${uploaded}/${total} souborů`;

        let bar = document.getElementById("progressBarUpload");
        bar.style.width = percent + "%";
        bar.innerText = percent + "%";

        const list = document.getElementById("uploadedList");

        // vytvoření nové položky
        const li = document.createElement("li");
        if (Boolean(responseOk)) {
            li.style.color = "green";
            li.textContent = `${index}.${fileName} — OK`;
        } else {
            li.style.color = "red";
            li.textContent = `${index}.${fileName} — ${trimmedErrorText}...`;
        }

        list.style.display = "";
        list.appendChild(li);

        const MAX_ITEMS = 5;

        while (list.children.length > MAX_ITEMS) {
            list.removeChild(list.firstElementChild);
        }
    }
</script>