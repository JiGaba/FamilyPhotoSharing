@using ModelLayer.Data
@model UserPasswordModel;
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@{
    ViewData["Title"] = "Změna uživatelského hesla";
}

<div class="modal fade" id="changePasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Změna hesla</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="mb-3">
                    <label asp-for="OldPassword" class="form-label">Původní heslo</label>
                    <input asp-for="OldPassword" type="password" class="form-control" />
                    <span asp-validation-for="OldPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label">Nové heslo</label>
                    <input asp-for="NewPassword" type="password" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmNewPassword" class="form-label">Potvrzení nového hesla</label>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control" onkeyup="validityCheck()" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                </div>

                <div id="passwordChangeMessage" class="text-danger"></div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-primary" onclick="submitPasswordChange(@Model.Id, '@Model.Login')">Změnit heslo</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zavřít</button>
            </div>
        </div>
    </div>
</div>

<script>
    function validityCheck(){
        const new1 = document.getElementById("NewPassword").value;
        const new2 = document.getElementById("ConfirmNewPassword").value;
        const msg = document.getElementById("passwordChangeMessage");

        msg.innerHTML = "";

        if (new1 !== new2) {
            msg.innerHTML = "Nová hesla se neshodují.";
            return false;
        }

        return true;
    }

    async function submitPasswordChange(userId, userLogin) {

        const oldPass = document.getElementById("OldPassword").value;
        const new1 = document.getElementById("NewPassword").value;
        const new2 = document.getElementById("ConfirmNewPassword").value;
        const msg = document.getElementById("passwordChangeMessage");

        msg.innerHTML = "";

        if(!validityCheck()) return;

        const response = await fetch("/User/ChangePassword", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                userId: userId,
                userLogin: userLogin,
                oldPassword: oldPass,
                newPassword: new1
            })
        });

        const result = await response.json();

        if (result.success) {
            msg.classList.remove("text-danger");
            msg.classList.add("text-success");
            msg.innerHTML = "Heslo bylo úspěšně změněno.";

            setTimeout(() => {
                const modal = bootstrap.Modal.getInstance(document.getElementById("changePasswordModal"));
                modal.hide();
            }, 1500);

        } else {
            msg.classList.add("text-danger");
            msg.innerHTML = result.message;
        }
    }

</script>
