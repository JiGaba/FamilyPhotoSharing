<style>
.custom-image-modal {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(0,0,0,0.9);
    text-align: center;
    padding-top: 40px;
}

.modal-image {
    max-width: 90%;
    max-height: 90%;
    height: auto;
    width: auto;
    margin: auto;
    display: block;
    border-radius: 6px;
    box-shadow: 0 0 20px rgba(255,255,255,0.3);
    background: transparent;
}
            
.modal-close {
    position: absolute;
    top: 20px;
    right: 35px;
    color: #fff;
    font-size: 40px;
    font-weight: bold;
    cursor: pointer;
    z-index: 10000;
}

.modal-close:hover {
    color: #bbb;
}
</style>

<div id="photoModal" class="custom-image-modal">
    <span class="modal-close">&times;</span>
    <img id="modalImage" class="modal-image"
        onerror="this.outerHTML='<div style=\'width:500px;height:500px;background:black;display:block;text-align:center;color:white\'>Fotografii se nepodařilo nalézt</div>'">
</div>