@{
    ViewBag.Title = "Login";
}
@await Html.PartialAsync("Partials/_InfoMessagePartial")

<div style="display:flex; justify-content:center; align-items:center;">
    <form method="post" style="display:block; width:50%">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
        <h2>Přihlášení</h2>
        <div class="mb-3">
            <label for="userLogin" class="form-label">Uživatelské jméno</label>
            <input type="text" name="userLogin" class="form-control" id="userLogin">
        </div>
        <div class="mb-3">
            <label for="password" class="form-label">Heslo</label>
            <input type="password" name="password" class="form-control" id="password">
        </div>
        <button type="submit" class="btn btn-primary">Přihlásit</button>
        <br/>
        <a asp-controller="Account" asp-action="ForgotPassword">
            Zapomenuté heslo?
        </a>
    </form>
</div>
