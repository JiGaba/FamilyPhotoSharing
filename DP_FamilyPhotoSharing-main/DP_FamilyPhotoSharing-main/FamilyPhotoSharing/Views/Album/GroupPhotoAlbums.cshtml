@using FamilyPhotoSharing.ViewsData
@using ModelLayer.System
@using System.Security.Claims
@{
    ViewData["Title"] = "Fotoalba - rodinná";
}
@{
    int index = 1;
}
@model List<PhotoAlbumView>;
@await Html.PartialAsync("Partials/_InfoMessagePartial")
@Html.Partial("Partials/_BackgroundServices")

<div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="display-4 mb-0">Rodinná fotoalba</h1>
    <a onclick="location.href='@Url.Action("GroupPhotoAlbum", "Album", new { albumId = 0 })'" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>
        <svg bootstrap-icon="Images" width="24" height="24" aria-label="GroupAlbumAdd"></svg> Přidat album
    </a>
</div>
<br />
<table class="table table-hover">
    <thead>
        <tr>
            <th>Pořadí</th>
            @if (User.FindFirst(ClaimTypes.Role)?.Value == UserRoles.Admin)
            {
                <th>ID</th>
            }
            <th>Název</th>
            <th>Poslední úprava</th>
            <th>Autor</th>
            <th class ="text-center">Počet fotografií</th>
            <th class="text-center">Zobrazit</th>
            @if (User.FindFirst(ClaimTypes.Role)?.Value == UserRoles.Admin || User.FindFirst(ClaimTypes.Role)?.Value == UserRoles.GroupAdmin)
            {
                <th class="text-center">Odstranit</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var album in Model)
        {
            <tr onclick="location.href='@Url.Action("GroupPhotoAlbum", "Album", new { albumId = album?.Id })'" style="cursor:pointer;">
                <td>@index.</td>
                @if (User.FindFirst(ClaimTypes.Role)?.Value == UserRoles.Admin)
                {
                    <td>@album?.Id</td>
                }
                <td>@album?.AlbumName</td>
                <td>@album?.CreateDateTime.ToString("dd.MM.yyyy")</td>
                <td>@album?.IAuthorName</td>
                <td class="text-center">@album?.PhotoCount</td>
                <td class="text-center">
                    <a href="/Gallery/ShowGroupAlbum?albumId=@album.Id"
                           title="Zobrazit album"
                           onclick="event.stopPropagation();">
                        <svg bootstrap-icon="DoorOpen" style="color:black" width="24" height="24"></svg>
                    </a>
                </td>
                @if (User.FindFirst(ClaimTypes.Role)?.Value == UserRoles.Admin || User.FindFirst(ClaimTypes.Role)?.Value == UserRoles.GroupAdmin)
                {
                    <td class="text-center">
                        <span title="Smazat sdílené album.">
                            <svg bootstrap-icon="Trash3Fill" onclick="event.stopPropagation();deleteAlbum(@album?.Id)" width="24" height="24" aria-label="Smazání sdíleného alba"></svg>
                        </span>
                    </td>
                }
            </tr>
            index++;
        }
    </tbody>
</table>

<script>
    async function deleteAlbum(albumId) {

        if (!confirm("Opravdu chcete smazat toto album? Fotografie budou přesunuty zpět do rodinné galerie podle původního oprávnění.")) {
            return;
        }

        BS_DeleteAlbum(albumId);
    }
</script>